# CarbonLens Environment Configuration
# Copy this to .env and fill in your values

# Groq API Key — PRIMARY: Used for OCR text → structured data extraction (Llama 3.3-70B)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API Key — SECONDARY: Used for PDF text parsing fallback
ANTHROPIC_API_KEY=your_claude_api_key_here

# Database
DATABASE_URL=sqlite:///./carbonlens.db

# OCR Engine Path (Windows users: point to your tesseract.exe)
# Default: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Poppler Path (Windows users: point to your poppler/bin folder)
# Required for PDF-to-image conversion in OCR service
POPPLER_PATH=C:\poppler-24.02.0\Library\bin

# App Settings
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
