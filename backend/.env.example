# CarbonLens Environment Configuration
# Copy this to .env and fill in your values

# Grok API Key (xAI) — PRIMARY: Used for OCR text → structured data extraction
GROK_API_KEY=your_grok_api_key_here

# Anthropic API Key — SECONDARY: Used for PDF text parsing fallback
ANTHROPIC_API_KEY=your_claude_api_key_here

# Database
DATABASE_URL=sqlite:///./carbonlens.db

# App Settings
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
